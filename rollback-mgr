            local scope_action=$(printf "1. User Level Only\n2. System Level Only\n3. Both" | fzf --prompt="Scope conflict for $TARGET_PKG (Esc to cancel) > " --height=6 --layout=reverse)
            case "$scope_action" in
                "1. User Level Only") PKG_TYPE="flatpak-user" ;;
                "2. System Level Only") PKG_TYPE="flatpak-system" ;;
                "3. Both") PKG_TYPE="flatpak-both" ;;
