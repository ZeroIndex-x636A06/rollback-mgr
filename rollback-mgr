    else
        add_hold_entry "$TARGET_PKG" "$PKG_TYPE" "$days"
    fi
    
    echo ""
    read -p "Press Enter to return to menu..."
}

# --- Background Check ---

check_holds() {
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
    export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"
    export DISPLAY="${DISPLAY:-:0}"
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"

    # Ensure Zenity is installed before attempting any GUI prompts
    if ! command -v zenity &> /dev/null; then
        local missing_action=""
        
        # Check if notify-send supports interactive actions
        if command -v notify-send &> /dev/null && notify-send --help 2>&1 | grep -q -- "--wait"; then
            missing_action=$(notify-send -u critical -a "Rollback Manager" "Error: Missing Dependency" \
                "Zenity is required for interactive prompts but is not installed." \
                --action="install=Install Zenity" --action="ignore=Dismiss" --wait 2>/dev/null)
        elif command -v notify-send &> /dev/null; then
            notify-send -u critical -a "Rollback Manager" "Error: Missing Dependency" "Zenity is required for interactive prompts but is not installed."
        fi

        # If the user clicked "Install Zenity", launch a terminal to run the sudo command
        if [ "$missing_action" = "install" ]; then
            local install_cmd=""
            if command -v pacman &> /dev/null; then
                install_cmd="sudo pacman -S zenity"
            elif command -v apt-get &> /dev/null; then
                install_cmd="sudo apt-get install -y zenity"
            elif command -v dnf &> /dev/null; then
                install_cmd="sudo dnf install -y zenity"
            fi
            
            if [ -n "$install_cmd" ]; then
                launch_terminal "echo 'Authenticating to install Zenity...'; $install_cmd"
            else
                launch_terminal "echo 'Could not determine package manager. Please install zenity manually.'"
            fi
        fi

        echo "Rollback Manager: Zenity is not installed. Exiting background check." >&2
        return 1
    fi

    local current_date=$(date +%s)
    local temp_file=$(mktemp)
    local expired_pkgs=() expired_types=() expired_exps=() expired_count=0
    
    while IFS='|' read -r pkg type exp_date; do
        if [ -z "$pkg" ]; then continue; fi
        if ! is_installed "$pkg" "$type"; then continue; fi

        # Bypass the expiration check for indefinite holds
        if [ "$exp_date" -eq 0 ]; then
            echo "$pkg|$type|$exp_date" >> "$temp_file"
            continue
        fi

        if [ "$current_date" -ge "$exp_date" ]; then
            expired_pkgs+=("$pkg")
            expired_types+=("$type")
            expired_exps+=("$exp_date")
            ((expired_count++))
        else
            echo "$pkg|$type|$exp_date" >> "$temp_file"
        fi
    done < "$HOLD_FILE"
    
    if [ $expired_count -eq 0 ]; then
        cat "$temp_file" > "$HOLD_FILE"
        rm -f "$temp_file"
        return
    fi
    
    local user_action=""
    local supports_wait=false

    # Safely check if the installed notify-send binary supports the --wait flag
    if command -v notify-send &> /dev/null && notify-send --help 2>&1 | grep -q -- "--wait"; then
        supports_wait=true
    fi

    if [ "$supports_wait" = true ]; then
        # Use the modern interactive notification
        user_action=$(notify-send -a "Rollback Manager" "Update Holds Expired" \
            "$expired_count package(s) have reached the end of their hold period." \
            --action="default=Review Holds" --action="review=Review Holds" --wait 2>/dev/null)
    else
        # Fallback for lightweight daemons: Send a standard notification so it hits the history/tray
        if command -v notify-send &> /dev/null; then
            notify-send -a "Rollback Manager" "Update Holds Expired" \
                "$expired_count package(s) have reached the end of their hold period." 2>/dev/null
        fi
        
        # Pop a Zenity dialog as the interactive fallback
        if zenity --question --title="Update Holds Expired" \
               --text="$expired_count package(s) have reached the end of their hold period.\n\nWould you like to review them now?" \
               --ok-label="Review Holds" --cancel-label="Later" 2>/dev/null; then
            user_action="review"
        else
            user_action="cancel"
        fi
    fi

    if [ "$user_action" != "review" ] && [ "$user_action" != "default" ]; then
        for i in "${!expired_pkgs[@]}"; do
            echo "${expired_pkgs[$i]}|${expired_types[$i]}|${expired_exps[$i]}" >> "$temp_file"
        done
        cat "$temp_file" > "$HOLD_FILE"
        rm -f "$temp_file"
        return 
    fi
    
    local pacman_pkgs="" flatpak_pkgs="" flatpak_user_pkgs="" flatpak_system_pkgs="" apt_pkgs="" dnf_pkgs=""
    
    for i in "${!expired_pkgs[@]}"; do
        local p="${expired_pkgs[$i]}"
        local t="${expired_types[$i]}"
        while true; do
            zenity --question --title="Hold Expired ($((i+1)) of $expired_count)" \
                   --text="Hold for $p ($t) has ended. Unhold and update?" \
                   --ok-label="Unhold & Update" --cancel-label="Hold longer" 2>/dev/null
            
            if [ $? -eq 0 ]; then
                echo "$p|$t|${expired_exps[$i]}" >> "$temp_file"
                case $t in
                    pacman) pacman_pkgs+="$p " ;;
                    flatpak) flatpak_pkgs+="$p " ;;
                    flatpak-user) flatpak_user_pkgs+="$p " ;;
                    flatpak-system) flatpak_system_pkgs+="$p " ;;
                    apt) apt_pkgs+="$p " ;;
                    dnf) dnf_pkgs+="$p " ;;
                esac
                break 
            else
                local extend_days=$(zenity --entry --title="Extend Hold" \
                    --text="Days to hold (0 for indefinite) $p? (Blank for default: $DEFAULT_EXTEND_DAYS)" \
                    --entry-text="$DEFAULT_EXTEND_DAYS" 2>/dev/null)
                
                if [ $? -eq 0 ]; then
                    local days=${extend_days:-$DEFAULT_EXTEND_DAYS}
                    if [[ "$days" =~ ^[0-9]+$ ]]; then
                        local new_exp
                        if [ "$days" -eq 0 ]; then
                            new_exp=0
                        else
                            new_exp=$(date -d "+$days days" +%s)
                        fi
                        echo "$p|$t|$new_exp" >> "$temp_file"
                        break 
                    fi
                else
                    continue
                fi
            fi
        done
    done
    
    cat "$temp_file" > "$HOLD_FILE"
    rm -f "$temp_file"
    
    local update_cmd=""
	if [ -n "$pacman_pkgs$flatpak_pkgs$flatpak_user_pkgs$flatpak_system_pkgs$apt_pkgs$dnf_pkgs" ]; then
        update_cmd="echo 'Authenticating...'; sudo -v; "
        
        if [ -n "$pacman_pkgs" ]; then
            for p in $pacman_pkgs; do update_cmd+="sudo bash -c \"sed -i 's/[[:space:]]*\\\\\b${p}\\\\\b//g' /etc/pacman.conf\" && sed -i \"/^${p}|pacman|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo pacman -S $pacman_pkgs; "
        fi
        if [ -n "$flatpak_user_pkgs" ]; then
            for p in $flatpak_user_pkgs; do update_cmd+="flatpak mask --remove --user ${p} $REDIRECT && sed -i \"/^${p}|flatpak-user|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="flatpak update -y --user $flatpak_user_pkgs; "
        fi
        if [ -n "$flatpak_system_pkgs" ]; then
            for p in $flatpak_system_pkgs; do update_cmd+="sudo flatpak mask --remove --system ${p} $REDIRECT && sed -i \"/^${p}|flatpak-system|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="flatpak update -y --system $flatpak_system_pkgs; "
        fi
        if [ -n "$flatpak_pkgs" ]; then
            for p in $flatpak_pkgs; do 
                update_cmd+="if flatpak list --columns=application,installation | grep -E \"^${p}[[:space:]]\" | grep -q \"user\"; then flatpak mask --remove --user ${p} $REDIRECT; fi; "
                update_cmd+="if flatpak list --columns=application,installation | grep -E \"^${p}[[:space:]]\" | grep -q \"system\"; then sudo flatpak mask --remove --system ${p} $REDIRECT; fi; "
                update_cmd+="sed -i \"/^${p}|flatpak|/d\" \"$HOLD_FILE\" ; "
            done
            update_cmd+="flatpak update -y $flatpak_pkgs; "
        fi
        if [ -n "$apt_pkgs" ]; then
            for p in $apt_pkgs; do update_cmd+="sudo apt-mark unhold ${p} $REDIRECT && sed -i \"/^${p}|apt|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo apt-get --only-upgrade install -y $apt_pkgs; "
        fi
        if [ -n "$dnf_pkgs" ]; then
            for p in $dnf_pkgs; do update_cmd+="sudo dnf versionlock delete ${p} $REDIRECT && sed -i \"/^${p}|dnf|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo dnf upgrade -y $dnf_pkgs; "
        fi
        
        update_cmd=$(printf "%s" "$update_cmd" | sed 's/[[:space:];]*$//')
        launch_terminal "$update_cmd"
    fi
}

# --- Execution ---

if [ "$1" == "check" ]; then
    check_holds
else
    setup_systemd_timer

    # Ensure fzf is installed before launching the interactive UI
    if ! command -v fzf &> /dev/null; then
        echo -e "Error: 'fzf' is required for the interactive menu.\n"
        read -p "Would you like to install it now? (y/N): " install_fzf
        if [[ "$install_fzf" =~ ^[Yy]$ ]]; then
            if command -v pacman &> /dev/null; then sudo pacman -S --noconfirm fzf;
            elif command -v apt-get &> /dev/null; then sudo apt-get install -y fzf;
            elif command -v dnf &> /dev/null; then sudo dnf install -y fzf;
            else echo "Please install fzf manually."; exit 1; fi
        else
            exit 1
        fi
    fi

    # Set the terminal tab title to rollback-mgr
    printf "\033]0;rollback-mgr\007"
    
    # Ensure the title clears if the user exits or hits Ctrl+C
    trap 'printf "\033]0;\007"; exit 0' EXIT INT TERM

    while true; do
        clear
        action=$(printf "1. Create new hold\n2. Manage active holds\n3. Downgrade package\n4. Exit" | fzf --prompt="Select action (Esc to cancel) > " --height=8 --layout=reverse)
        case "$action" in
            "1. Create new hold") create_hold_wizard ;;
            "2. Manage active holds") manage_holds ;;
            "3. Downgrade package") downgrade_wizard ;;
            *) exit 0 ;;
        esac
    done
fi
