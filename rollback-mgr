#!/bin/bash

# Configuration
CONFIG_DIR="$HOME/.config/rollback-mgr"
HOLD_FILE="$CONFIG_DIR/holds.txt"
DEFAULT_EXTEND_DAYS=7

# Ensure config directory and file exist
mkdir -p "$CONFIG_DIR"
touch "$HOLD_FILE"

# --- Global Flags ---

VERBOSE=false
while [[ "$1" == -* ]]; do
    case "$1" in
        -v|--verbose) VERBOSE=true; shift ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

if [ "$VERBOSE" = true ]; then
    REDIRECT=""
else
    REDIRECT=">/dev/null 2>&1"
fi

exec_quiet() {
    if [ "$VERBOSE" = true ]; then
        "$@"
    else
        "$@" >/dev/null 2>&1
    fi
}

# --- Background Setup ---

setup_systemd_timer() {
    local script_path=$(realpath "$0")
    local systemd_dir="$HOME/.config/systemd/user"
    local service_file="$systemd_dir/rollback-mgr.service"
    local timer_file="$systemd_dir/rollback-mgr.timer"

    if [ ! -f "$timer_file" ]; then
        mkdir -p "$systemd_dir"

        cat > "$service_file" <<EOF
[Unit]
Description=Rollback Manager Daily Check

[Service]
Type=oneshot
ExecStart=$script_path check
EOF

        cat > "$timer_file" <<EOF
[Unit]
Description=Run Rollback Manager Daily at 12:00

[Timer]
OnCalendar=*-*-* 12:00:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

        systemctl --user daemon-reload
        systemctl --user enable --now rollback-mgr.timer
    fi
}

# --- Core Functions ---

start_spinner() {
    local message="$1"
    if [ "$VERBOSE" = true ]; then
        echo -e "\n>>> $message"
        return
    fi
    tput civis # Hide the cursor
    while true; do
        for x in '-' '\' '|' '/'; do
            echo -ne "\r$message $x"
            sleep 0.1
        done
    done &
    SPINNER_PID=$!
}

stop_spinner() {
    if [ "$VERBOSE" = true ]; then return; fi
    if [ -n "$SPINNER_PID" ]; then
        kill $SPINNER_PID &>/dev/null
        wait $SPINNER_PID 2>/dev/null
        unset SPINNER_PID
    fi
    echo -ne "\r\033[K" # Clear the line
    tput cnorm         # Restore the cursor
}

launch_terminal() {
    local cmd="$1"
    if command -v alacritty &> /dev/null; then
        alacritty -T "rollback-mgr" -e bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v kitty &> /dev/null; then
        kitty -T "rollback-mgr" bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v ptyxis &> /dev/null; then
        ptyxis --title="rollback-mgr" -- bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v gnome-terminal &> /dev/null; then
        gnome-terminal --title="rollback-mgr" -- bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v konsole &> /dev/null; then
        konsole -p tabtitle="rollback-mgr" -e bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    else
        x-terminal-emulator -e bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    fi
}

get_available_managers() {
    local managers=""
    if command -v flatpak &> /dev/null; then managers+="flatpak\n"; fi
    if command -v apt-get &> /dev/null; then managers+="apt\n"; fi
    if command -v dnf &> /dev/null; then managers+="dnf\n"; fi
    if command -v pacman &> /dev/null; then managers+="pacman\n"; fi
    printf "%b" "$managers" | sed '/^$/d'
}

is_installed() {
    local pkg=$1
    local type=$2
    case $type in
        flatpak|flatpak-user|flatpak-system) flatpak info "$pkg" &>/dev/null ;;
        apt) dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "ok installed" ;;
        dnf) dnf list installed "$pkg" &>/dev/null ;;
        pacman) pacman -Qq "$pkg" &>/dev/null ;;
    esac
}

apply_hold() {
    local pkg=$1
    local type=$2
    
    case $type in
        flatpak-user) exec_quiet flatpak mask --user "$pkg" ;;
        flatpak-system) exec_quiet sudo flatpak mask --system "$pkg" ;;
        flatpak) # Legacy fallback
            if flatpak list --columns=application,installation | grep -E "^$pkg[[:space:]]" | grep -q "user"; then exec_quiet flatpak mask --user "$pkg"; fi
            if flatpak list --columns=application,installation | grep -E "^$pkg[[:space:]]" | grep -q "system"; then exec_quiet sudo flatpak mask --system "$pkg"; fi
            ;;
        apt) exec_quiet sudo apt-mark hold "$pkg" ;;
        dnf) 
            if ! dnf versionlock --help >/dev/null 2>&1; then exec_quiet sudo dnf install -y 'dnf-command(versionlock)'; fi
            exec_quiet sudo dnf versionlock add "$pkg" ;;
        pacman) 
            exec_quiet sudo bash -c '
                if ! grep -q "^#\?[[:space:]]*IgnorePkg" /etc/pacman.conf; then sed -i "/^\[options\]/a IgnorePkg = '"$1"'" /etc/pacman.conf
                else sed -i "s/^#[[:space:]]*IgnorePkg/IgnorePkg/" /etc/pacman.conf; if ! grep -q "^IgnorePkg.*\\b'"$1"'\\b" /etc/pacman.conf; then sed -i "/^IgnorePkg/ s/$/ '"$1"'/" /etc/pacman.conf; fi; fi' ;;
    esac
}

remove_hold() {
    local pkg=$1
    local type=$2
    
    case $type in
        flatpak-user) exec_quiet flatpak mask --remove --user "$pkg" ;;
        flatpak-system) exec_quiet sudo flatpak mask --remove --system "$pkg" ;;
        flatpak) # Legacy fallback
            if flatpak list --columns=application,installation | grep -E "^$pkg[[:space:]]" | grep -q "user"; then exec_quiet flatpak mask --remove --user "$pkg"; fi
            if flatpak list --columns=application,installation | grep -E "^$pkg[[:space:]]" | grep -q "system"; then exec_quiet sudo flatpak mask --remove --system "$pkg"; fi
            ;;
        apt) exec_quiet sudo apt-mark unhold "$pkg" ;;
        dnf) exec_quiet sudo dnf versionlock delete "$pkg" ;;
        pacman) exec_quiet sudo bash -c "sed -i 's/[[:space:]]*\b$pkg\b//g' /etc/pacman.conf" ;;
    esac
}

add_hold_entry() {
    local pkg=$1
    local type=$2
    local days=$3
    
    local exp_date
    if [ "$days" -eq 0 ]; then
        exp_date=0
    else
        exp_date=$(date -d "+$days days" +%s)
    fi
    
    local already_held=false
    if grep -q "^$pkg|$type|" "$HOLD_FILE"; then
        already_held=true
    fi
    
    sed -i "/^$pkg|$type|/d" "$HOLD_FILE"
    echo "$pkg|$type|$exp_date" >> "$HOLD_FILE"
    
    apply_hold "$pkg" "$type"
    
    if [ "$already_held" = true ]; then
        if [ "$days" -eq 0 ]; then
            echo "Package $pkg ($type) is already being held. Expiration updated to Indefinite."
        else
            echo "Package $pkg ($type) is already being held. Expiration updated to $days days."
        fi
    else
        if [ "$days" -eq 0 ]; then
            echo "Successfully placed indefinite hold on $pkg ($type)."
        else
            echo "Successfully placed hold on $pkg ($type) for $days days."
        fi
    fi
}

# --- Downgrade Logic ---

perform_downgrade() {
    local pkg=$1
    local type=$2
    
    echo -e "\n--- Downgrading $pkg ---"
    
    sed -i "/^$pkg|$type|/d" "$HOLD_FILE"
    remove_hold "$pkg" "$type"
    
    case $type in
        pacman)
            local try_aur_fallback=false

            if pacman -Qm | awk '{print $1}' | grep -qx "$pkg"; then
                try_aur_fallback=true
            else
		if ! command -v downgrade &> /dev/null; then
                    start_spinner "Installing 'downgrade' utility..."
                    exec_quiet sudo pacman -S --noconfirm downgrade
                    stop_spinner
                fi
                
                sudo downgrade --ignore never "$pkg"
                
                if [ $? -eq 0 ]; then
                    return 0
                else
                    read -p "Official archive check failed. Try AUR commit history? (y/N): " fallback_ans
                    if [[ "$fallback_ans" =~ ^[Yy]$ ]]; then
                        try_aur_fallback=true
                    else
                        return 1
                    fi
                fi
            fi

            if [ "$try_aur_fallback" = true ]; then
                local orig_dir=$(pwd)
                local temp_dir=$(mktemp -d)
                cd "$temp_dir" || return 1
                
		start_spinner "Cloning AUR repository and fetching commits..."
                if ! exec_quiet git clone "https://aur.archlinux.org/${pkg}.git" .; then
                    stop_spinner
                    echo -e "\nFailed to clone AUR repository."
                    cd "$orig_dir"
                    rm -rf "$temp_dir"
                    return 1
                else
                    local current_ver=$(pacman -Q "$pkg" 2>/dev/null | awk '{print $2}')
                    local commits=$(git log --pretty=format:"%h | %cd | %s" --date=short 2>/dev/null)
                    stop_spinner

                    if [ -z "$commits" ]; then
                        echo -e "\nNo commit history found in the AUR for $pkg."
                        cd "$orig_dir"
                        rm -rf "$temp_dir"
                        return 1
                    fi

                    local selected_commit=$(echo "$commits" | column -t -s '|' | fzf --prompt="Select AUR commit (Esc to cancel) > " --header="Currently installed: $current_ver" --height=15 --layout=reverse)
                    
		    if [ -n "$selected_commit" ]; then
                        local hash=$(echo "$selected_commit" | awk '{print $1}')
                        exec_quiet git checkout "$hash"
                        
                        echo -e "\nBuilding and installing package..."
                        if makepkg -si; then
                            cd "$orig_dir"
                            rm -rf "$temp_dir"
                            return 0
                        else
                            echo -e "\nError: AUR build or installation failed."
                            cd "$orig_dir"
                            rm -rf "$temp_dir"
                            return 1
                        fi
                    else
                        cd "$orig_dir"
                        rm -rf "$temp_dir"
                        return 1
                    fi
                fi
            fi
            ;;
        flatpak-user|flatpak-system|flatpak)
            local target_install="system"
            if [ "$type" == "flatpak-user" ]; then target_install="user"; fi
            if [ "$type" == "flatpak" ]; then
                target_install=$(flatpak list --columns=application,installation | grep -E "^$pkg[[:space:]]" | awk '{print $2}' | head -n 1)
            fi

            local flatpak_info=$(flatpak list --columns=application,origin,installation | grep -E "^$pkg[[:space:]]" | grep "$target_install" | head -n 1)
            local remote=$(echo "$flatpak_info" | awk '{print $2}')
            local install_type=$(echo "$flatpak_info" | awk '{print $3}')
            
            if [ -z "$remote" ]; then return 1; fi
            
            start_spinner "Fetching Flatpak commit history for $install_type..."
            local raw_log=$(LC_ALL=C flatpak remote-info --log --${install_type} "$remote" "$pkg" 2>/dev/null)
            
            if [ -z "$raw_log" ]; then 
                stop_spinner
                return 1
            fi
            
            local current_commit=$(flatpak info --show-commit --${install_type} "$pkg" 2>/dev/null)
            local commits=$(echo "$raw_log" | awk '/^[ \t]*Commit:/ {c=$2} /^[ \t]*Date:/ {d=$0; sub(/^[ \t]*Date:[ \t]*/, "", d); print c " | " d}')
            local formatted_commits=$(echo "$commits" | awk -F' \\| ' -v curr="$current_commit" '{ if ($1 == curr) print $1 " | " $2 "  <-- (Installed)"; else print $1 " | " $2 }')
            stop_spinner

            local selected_commit=$(echo "$formatted_commits" | column -t -s '|' | fzf --prompt="Select $install_type commit (Esc to cancel) > " --height=15 --layout=reverse)
            
            if [ -n "$selected_commit" ]; then
                local hash=$(echo "$selected_commit" | awk '{print $1}')
                if [ "$install_type" == "system" ]; then
                    sudo flatpak update -y --system --commit="$hash" "$pkg"
                else
                    flatpak update -y --user --commit="$hash" "$pkg"
                fi
                return $?
            else
                return 1
            fi
            ;;
        apt)
            local current_ver=$(dpkg-query -W -f='${Version}' "$pkg" 2>/dev/null)
            
            start_spinner "Fetching APT local cache..."
            local versions=$(apt-cache madison "$pkg" | awk '{print $3}')
            local version_count=$(echo "$versions" | wc -w)
            stop_spinner

            if [ "$version_count" -gt 1 ]; then
                local formatted_versions=$(echo "$versions" | awk -v curr="$current_ver" '{ if ($1 == curr) print $0 "  <-- (Installed)"; else print $0 }')
                local selected=$(echo "$formatted_versions" | fzf --prompt="Select version (Esc to cancel) > " --height=10 --layout=reverse)
                local selected_version=$(echo "$selected" | awk '{print $1}')
                
                if [ -n "$selected_version" ]; then
                    sudo apt-get install -y "$pkg=$selected_version"
                    return $?
                else
                    return 1
                fi
            else
                echo -e "Only one version found in local APT repositories."
                read -p "Search the Debian Snapshot Archive (Historical Time Machine)? (y/N): " snap_ans
                if [[ "$snap_ans" =~ ^[Yy]$ ]]; then
                    
                    start_spinner "Querying Debian Snapshot API for $pkg..."
                    local snap_versions=$(curl -sL "https://snapshot.debian.org/mr/binary/$pkg/" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print('\n'.join(x['version'] for x in d.get('result', [])))
except Exception:
    pass
" 2>/dev/null)
                    stop_spinner

                    if [ -z "$snap_versions" ]; then
                        echo "No historical versions found."
                        return 1
                    fi
                    
                    local formatted_snap=$(echo "$snap_versions" | awk -v curr="$current_ver" '{ if ($1 == curr) print $0 "  <-- (Installed)"; else print $0 }')
                    local selected=$(echo "$formatted_snap" | fzf --prompt="Select historical version (Esc to cancel) > " --height=15 --layout=reverse)
                    local selected_version=$(echo "$selected" | awk '{print $1}')
                    
                    if [ -n "$selected_version" ]; then
                        local arch=$(dpkg --print-architecture)
                        
                        start_spinner "Finding compiled .deb hash for architecture: $arch..."
                        local hash=$(curl -sL "https://snapshot.debian.org/mr/binary/$pkg/$selected_version/binfiles" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    arch = '$arch'
    res = [x['hash'] for x in d.get('result', []) if x.get('architecture') in (arch, 'all')]
    if res:
        print(res[0])
except Exception:
    pass
" 2>/dev/null)
                        stop_spinner
                        
                        if [ -z "$hash" ]; then
                            echo "Could not find a pre-compiled .deb for $arch."
                            return 1
                        fi
                        
                        echo "Downloading package..."
                        local tmp_deb="/tmp/${pkg}_${selected_version}.deb"
                        wget -q --show-progress "https://snapshot.debian.org/file/$hash" -O "$tmp_deb"
                        
                        if [ -f "$tmp_deb" ]; then
                            echo "Installing package..."
                            sudo dpkg -i "$tmp_deb"
                            local status=$?
                            rm -f "$tmp_deb"
                            return $status
                        else
                            echo "Download failed."
                            return 1
                        fi
                    else
                        return 1
                    fi
                else
                    return 1
                fi
            fi
            ;;
        dnf)
            start_spinner "Fetching DNF duplicate versions..."
            local current_ver=$(dnf list installed "$pkg" 2>/dev/null | awk 'NR>1 {print $2}')
            local versions=$(dnf --showduplicates list "$pkg" | awk 'NR>2 {print $2}')
            local formatted_versions=$(echo "$versions" | awk -v curr="$current_ver" '{ if ($1 == curr) print $0 "  <-- (Installed)"; else print $0 }')
            stop_spinner
            
            local selected=$(echo "$formatted_versions" | fzf --prompt="Select version (Esc to cancel) > " --height=10 --layout=reverse)
            local selected_version=$(echo "$selected" | awk '{print $1}')
            
            if [ -n "$selected_version" ]; then
                sudo dnf downgrade -y "$pkg-$selected_version"
                return $?
            else
                return 1
            fi
            ;;
    esac
}

# --- Menus ---

manage_holds() {
    while true; do
        if [ ! -s "$HOLD_FILE" ]; then 
            clear
            echo "=== Manage Active Holds ==="
            echo "No holds are currently active."
            echo ""
            read -p "Press Enter to return to menu..."
            return
        fi

        local formatted_list=""
        while IFS='|' read -r pkg type exp_date; do
            if [ -n "$pkg" ]; then
                if is_installed "$pkg" "$type"; then
                    local human_date
                    if [ "$exp_date" -eq 0 ]; then
                        human_date="Indefinite"
                    else
                        human_date=$(date -d "@$exp_date" "+%b %d, %Y %I:%M %p")
                    fi
                    formatted_list+="$pkg|$type|$human_date\n"
                else
                    sed -i "/^$pkg|$type|/d" "$HOLD_FILE"
                fi
            fi
        done < "$HOLD_FILE"

        if [ -z "$formatted_list" ]; then 
            clear
            echo "=== Manage Active Holds ==="
            echo "No holds are currently active."
            echo ""
            read -p "Press Enter to return to menu..."
            return
        fi

        clear
        local selected=$(echo -e "$formatted_list" | column -t -s '|' | fzf --prompt="Select hold (Esc to exit) > " --height=15 --layout=reverse --header="PACKAGE  TYPE  EXPIRES")

        if [ -z "$selected" ]; then return; fi

        local target_pkg=$(echo "$selected" | awk '{print $1}')
        local target_type=$(echo "$selected" | awk '{print $2}')

        local action=$(printf "1. Change duration\n2. Remove hold\n3. Cancel" | fzf --prompt="Action for $target_pkg (Esc to cancel) > " --height=6 --layout=reverse)

        case "$action" in
            "1. Change duration")
                read -p "Enter new hold days (0 for indefinite): " new_days
                if [[ "$new_days" =~ ^[0-9]+$ ]]; then
                    local new_exp
                    if [ "$new_days" -eq 0 ]; then
                        new_exp=0
                    else
                        new_exp=$(date -d "+$new_days days" +%s)
                    fi
                    sed -i "/^$target_pkg|$target_type|/d" "$HOLD_FILE"
                    echo "$target_pkg|$target_type|$new_exp" >> "$HOLD_FILE"
                fi
                ;;
            "2. Remove hold")
                read -p "Remove hold on $target_pkg? (y/n): " confirm
                if [[ "$confirm" =~ ^[Yy]$ ]]; then
                    remove_hold "$target_pkg" "$target_type"
                    sed -i "/^$target_pkg|$target_type|/d" "$HOLD_FILE"
                fi
                ;;
            *) continue ;;
        esac
    done
}

downgrade_wizard() {
    local PKG_TYPE=$(get_available_managers | fzf --prompt="Select manager (Esc to cancel) > " --height=10 --layout=reverse)
    if [ -z "$PKG_TYPE" ]; then return; fi
    
    local PKG_LIST=""
    case $PKG_TYPE in
        flatpak) PKG_LIST=$(flatpak list --columns=application | sort | uniq) ;;
        apt) PKG_LIST=$(dpkg-query -f '${Package}\n' -W) ;;
        dnf) PKG_LIST=$(dnf list installed | awk 'NR>1 {print $1}') ;;
        pacman) PKG_LIST=$(pacman -Qq) ;;
    esac
    
    local TARGET_PKG=$(echo "$PKG_LIST" | fzf --prompt="Select package (Esc to cancel) > " --height=15 --layout=reverse)
    if [ -z "$TARGET_PKG" ]; then return; fi
    
    # --- FLATPAK SCOPE RESOLUTION ---
    if [ "$PKG_TYPE" == "flatpak" ]; then
        local scopes=$(flatpak list --columns=application,installation | grep -E "^$TARGET_PKG[[:space:]]" | awk '{print $2}')
        if [ "$(echo "$scopes" | wc -w)" -gt 1 ]; then
            local scope_action=$(printf "1. User Level Only\n2. System Level Only\n3. Both" | fzf --prompt="Scope conflict for $TARGET_PKG (Esc to cancel) > " --height=6 --layout=reverse)
            case "$scope_action" in
                "1. User Level Only") PKG_TYPE="flatpak-user" ;;
                "2. System Level Only") PKG_TYPE="flatpak-system" ;;
                "3. Both") PKG_TYPE="flatpak-both" ;;
                *) return ;;
            esac
        else
            if echo "$scopes" | grep -q "user"; then PKG_TYPE="flatpak-user"; else PKG_TYPE="flatpak-system"; fi
        fi
    fi

    local success=false
    if [ "$PKG_TYPE" == "flatpak-both" ]; then
        perform_downgrade "$TARGET_PKG" "flatpak-user"
        local res1=$?
        perform_downgrade "$TARGET_PKG" "flatpak-system"
        local res2=$?
        if [ $res1 -eq 0 ] || [ $res2 -eq 0 ]; then success=true; fi
    else
        perform_downgrade "$TARGET_PKG" "$PKG_TYPE"
        if [ $? -eq 0 ]; then success=true; fi
    fi
    
    if [ "$success" = true ]; then
        echo ""
        read -p "Place hold on $TARGET_PKG? (y/N): " hold_ans
        if [[ "$hold_ans" =~ ^[Yy]$ ]]; then
            read -p "Days to hold (0 for indefinite) [Default: 7]: " HOLD_DAYS
            local days=${HOLD_DAYS:-7}
            if [ "$PKG_TYPE" == "flatpak-both" ]; then
                add_hold_entry "$TARGET_PKG" "flatpak-user" "$days"
                add_hold_entry "$TARGET_PKG" "flatpak-system" "$days"
            else
                add_hold_entry "$TARGET_PKG" "$PKG_TYPE" "$days"
            fi
        fi
    else
        echo -e "\nDowngrade cancelled or failed."
    fi
    
    echo ""
    read -p "Press Enter to return to menu..."
}

