#!/bin/bash

# Configuration
CONFIG_DIR="$HOME/.config/rollback-mgr"
HOLD_FILE="$CONFIG_DIR/holds.txt"
DEFAULT_EXTEND_DAYS=7

# Ensure config directory and file exist
mkdir -p "$CONFIG_DIR"
touch "$HOLD_FILE"

# --- Background Setup ---

setup_systemd_timer() {
    local script_path=$(realpath "$0")
    local systemd_dir="$HOME/.config/systemd/user"
    local service_file="$systemd_dir/rollback-mgr.service"
    local timer_file="$systemd_dir/rollback-mgr.timer"

    if [ ! -f "$timer_file" ]; then
        mkdir -p "$systemd_dir"

        cat > "$service_file" <<EOF
[Unit]
Description=Rollback Manager Daily Check

[Service]
Type=oneshot
Environment="DISPLAY=:0"
Environment="DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/$(id -u)/bus"
ExecStart=$script_path check
EOF

        cat > "$timer_file" <<EOF
[Unit]
Description=Run Rollback Manager Daily at 12:00

[Timer]
OnCalendar=*-*-* 12:00:00
Persistent=true

[Install]
WantedBy=timers.target
EOF

        systemctl --user daemon-reload
        systemctl --user enable --now rollback-mgr.timer
    fi
}

# --- Core Functions ---

launch_terminal() {
    local cmd="$1"
    if command -v alacritty &> /dev/null; then
        alacritty -T "rollback-mgr" -e bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v kitty &> /dev/null; then
        kitty -T "rollback-mgr" bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v ptyxis &> /dev/null; then
        ptyxis --title="rollback-mgr" -- bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v gnome-terminal &> /dev/null; then
        gnome-terminal --title="rollback-mgr" -- bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    elif command -v konsole &> /dev/null; then
        konsole -p tabtitle="rollback-mgr" -e bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    else
        x-terminal-emulator -e bash -c "$cmd; echo ''; read -p 'Press Enter to close...'"
    fi
}

is_installed() {
    local pkg=$1
    local type=$2
    case $type in
        flatpak) flatpak info "$pkg" &>/dev/null ;;
        apt) dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "ok installed" ;;
        dnf) dnf list installed "$pkg" &>/dev/null ;;
        pacman) pacman -Qq "$pkg" &>/dev/null ;;
    esac
}

apply_hold() {
    local pkg=$1
    local type=$2
    
    case $type in
        flatpak) sudo flatpak mask "$pkg" >/dev/null 2>&1 ;;
        apt) sudo apt-mark hold "$pkg" >/dev/null 2>&1 ;;
        dnf) sudo dnf versionlock add "$pkg" >/dev/null 2>&1 ;;
        pacman) 
            sudo bash -c "grep -q '^IgnorePkg' /etc/pacman.conf || sed -i 's/^#IgnorePkg.*/IgnorePkg =/' /etc/pacman.conf; sed -i '/^IgnorePkg/ s/$/ $pkg/' /etc/pacman.conf"
            ;;
    esac
}

remove_hold() {
    local pkg=$1
    local type=$2
    
    case $type in
        flatpak) sudo flatpak mask --remove "$pkg" >/dev/null 2>&1 ;;
        apt) sudo apt-mark unhold "$pkg" >/dev/null 2>&1 ;;
        dnf) sudo dnf versionlock delete "$pkg" >/dev/null 2>&1 ;;
        pacman) 
            sudo bash -c "sed -i 's/[[:space:]]*\b$pkg\b//g' /etc/pacman.conf"
            ;;
    esac
}

add_hold_entry() {
    local pkg=$1
    local type=$2
    local days=$3
    
    local exp_date=$(date -d "+$days days" +%s)
    
    sed -i "/^$pkg|$type|/d" "$HOLD_FILE"
    echo "$pkg|$type|$exp_date" >> "$HOLD_FILE"
    
    apply_hold "$pkg" "$type"
    echo "Successfully placed hold on $pkg ($type) for $days days."
}

# --- Downgrade Logic ---

perform_downgrade() {
    local pkg=$1
    local type=$2
    
    echo -e "\n--- Downgrading $pkg ---"
    
    sed -i "/^$pkg|$type|/d" "$HOLD_FILE"
    remove_hold "$pkg" "$type"
    
    case $type in
        pacman)
            local try_aur_fallback=false

            if pacman -Qm | awk '{print $1}' | grep -qx "$pkg"; then
                try_aur_fallback=true
            else
                if ! command -v downgrade &> /dev/null; then
                    sudo pacman -S --noconfirm downgrade
                fi
                
                sudo downgrade "$pkg"
                
                if [ $? -eq 0 ]; then
                    return 0
                else
                    read -p "Official archive check failed. Try AUR commit history? (y/N): " fallback_ans
                    if [[ "$fallback_ans" =~ ^[Yy]$ ]]; then
                        try_aur_fallback=true
                    else
                        return 1
                    fi
                fi
            fi

            if [ "$try_aur_fallback" = true ]; then
                local orig_dir=$(pwd)
                local temp_dir=$(mktemp -d)
                cd "$temp_dir" || return 1
                
                if ! git clone "https://aur.archlinux.org/${pkg}.git" . &>/dev/null; then
                    echo "Failed to clone AUR repository."
                    cd "$orig_dir"
                    rm -rf "$temp_dir"
                    return 1
                else
                    local commits=$(git log --pretty=format:"%h | %cd | %s" --date=short)
                    local selected_commit=$(echo "$commits" | column -t -s '|' | fzf --prompt="Select AUR commit (Esc to cancel) > " --height=15 --layout=reverse)
                    
                    if [ -n "$selected_commit" ]; then
                        local hash=$(echo "$selected_commit" | awk '{print $1}')
                        git checkout "$hash" &>/dev/null
                        makepkg -si
                        
                        cd "$orig_dir"
                        rm -rf "$temp_dir"
                        return 0
                    else
                        cd "$orig_dir"
                        rm -rf "$temp_dir"
                        return 1
                    fi
                fi
            fi
            ;;
            
        flatpak)
            local flatpak_info=$(flatpak list --columns=application,origin,installation | grep "^$pkg\s")
            local remote=$(echo "$flatpak_info" | awk '{print $2}')
            local install_type=$(echo "$flatpak_info" | awk '{print $3}')
            
            if [ -z "$remote" ]; then return 1; fi
            
            local raw_log=$(LC_ALL=C flatpak remote-info --log --${install_type} "$remote" "$pkg" 2>/dev/null)
            if [ -z "$raw_log" ]; then return 1; fi
            
            local commits=$(echo "$raw_log" | awk '/^[ \t]*Commit:/ {c=$2} /^[ \t]*Date:/ {d=$0; sub(/^[ \t]*Date:[ \t]*/, "", d); print c " | " d}')
            local selected_commit=$(echo "$commits" | column -t -s '|' | fzf --prompt="Select commit (Esc to cancel) > " --height=15 --layout=reverse)
            
            if [ -n "$selected_commit" ]; then
                local hash=$(echo "$selected_commit" | awk '{print $1}')
                if [ "$install_type" == "system" ]; then
                    sudo flatpak update -y --system --commit="$hash" "$pkg"
                else
                    flatpak update -y --user --commit="$hash" "$pkg"
                fi
                return $?
            else
                return 1
            fi
            ;;
            
        apt)
            local versions=$(apt-cache madison "$pkg" | awk '{print $3}')
            local version_count=$(echo "$versions" | wc -w)
            
            if [ "$version_count" -gt 1 ]; then
                local selected_version=$(echo "$versions" | fzf --prompt="Select version (Esc to cancel) > " --height=10 --layout=reverse)
                if [ -n "$selected_version" ]; then
                    sudo apt-get install -y "$pkg=$selected_version"
                    return $?
                else
                    return 1
                fi
            else
                echo -e "Only one version found in local APT repositories."
                read -p "Search the Debian Snapshot Archive (Historical Time Machine)? (y/N): " snap_ans
                if [[ "$snap_ans" =~ ^[Yy]$ ]]; then
                    echo "Querying Debian Snapshot API for $pkg..."
                    local snap_versions=$(curl -sL "https://snapshot.debian.org/mr/package/$pkg/" | python3 -c "import sys, json; d=json.load(sys.stdin); print('\n'.join(x['version'] for x in d.get('result', [])))" 2>/dev/null)
                    
                    if [ -z "$snap_versions" ]; then
                        echo "No historical versions found."
                        return 1
                    fi
                    
                    local selected_version=$(echo "$snap_versions" | fzf --prompt="Select historical version (Esc to cancel) > " --height=15 --layout=reverse)
                    
                    if [ -n "$selected_version" ]; then
                        local arch=$(dpkg --print-architecture)
                        echo "Finding compiled .deb hash for architecture: $arch..."
                        local hash=$(curl -sL "https://snapshot.debian.org/mr/package/$pkg/$selected_version/binfiles?architecture=$arch" | python3 -c "import sys, json; d=json.load(sys.stdin); print(d['result'][0]['hash'] if d.get('result') else '')" 2>/dev/null)
                        
                        if [ -z "$hash" ]; then
                            echo "Could not find a pre-compiled .deb for $arch."
                            return 1
                        fi
                        
                        echo "Downloading package..."
                        local tmp_deb="/tmp/${pkg}_${selected_version}.deb"
                        wget -q --show-progress "https://snapshot.debian.org/file/$hash" -O "$tmp_deb"
                        
                        if [ -f "$tmp_deb" ]; then
                            echo "Installing package..."
                            sudo dpkg -i "$tmp_deb"
                            local status=$?
                            rm -f "$tmp_deb"
                            return $status
                        else
                            echo "Download failed."
                            return 1
                        fi
                    else
                        return 1
                    fi
                else
                    return 1
                fi
            fi
            ;;
            
        dnf)
            local versions=$(dnf --showduplicates list "$pkg" | awk 'NR>2 {print $2}')
            local selected_version=$(echo "$versions" | fzf --prompt="Select version (Esc to cancel) > " --height=10 --layout=reverse)
            if [ -n "$selected_version" ]; then
                sudo dnf downgrade -y "$pkg-$selected_version"
                return $?
            else
                return 1
            fi
            ;;
    esac
}

# --- Menus ---

manage_holds() {
    while true; do
        if [ ! -s "$HOLD_FILE" ]; then return; fi

        local formatted_list=""
        while IFS='|' read -r pkg type exp_date; do
            if [ -n "$pkg" ]; then
                if is_installed "$pkg" "$type"; then
                    local human_date=$(date -d "@$exp_date" "+%b %d, %Y %I:%M %p")
                    formatted_list+="$pkg|$type|$human_date\n"
                else
                    sed -i "/^$pkg|$type|/d" "$HOLD_FILE"
                fi
            fi
        done < "$HOLD_FILE"

        if [ -z "$formatted_list" ]; then return; fi

        clear
        local selected=$(echo -e "$formatted_list" | column -t -s '|' | fzf --prompt="Select hold (Esc to exit) > " --height=15 --layout=reverse --header="PACKAGE  TYPE  EXPIRES")

        if [ -z "$selected" ]; then return; fi

        local target_pkg=$(echo "$selected" | awk '{print $1}')
        local target_type=$(echo "$selected" | awk '{print $2}')

        local action=$(printf "1. Change duration\n2. Remove hold\n3. Cancel" | fzf --prompt="Action for $target_pkg (Esc to cancel) > " --height=6 --layout=reverse)

        case "$action" in
            "1. Change duration")
                read -p "Enter new hold days: " new_days
                if [[ "$new_days" =~ ^[0-9]+$ ]]; then
                    local new_exp=$(date -d "+$new_days days" +%s)
                    sed -i "/^$target_pkg|$target_type|/d" "$HOLD_FILE"
                    echo "$target_pkg|$target_type|$new_exp" >> "$HOLD_FILE"
                fi
                ;;
            "2. Remove hold")
                read -p "Remove hold on $target_pkg? (y/n): " confirm
                if [[ "$confirm" =~ ^[Yy]$ ]]; then
                    remove_hold "$target_pkg" "$target_type"
                    sed -i "/^$target_pkg|$target_type|/d" "$HOLD_FILE"
                fi
                ;;
            *) continue ;;
        esac
    done
}

downgrade_wizard() {
    local PKG_TYPE=$(printf "flatpak\napt\ndnf\npacman" | fzf --prompt="Select manager (Esc to cancel) > " --height=10 --layout=reverse)
    if [ -z "$PKG_TYPE" ]; then return; fi
    
    local PKG_LIST=""
    case $PKG_TYPE in
        flatpak) PKG_LIST=$(flatpak list --columns=application) ;;
        apt) PKG_LIST=$(dpkg-query -f '${Package}\n' -W) ;;
        dnf) PKG_LIST=$(dnf list installed | awk 'NR>1 {print $1}') ;;
        pacman) PKG_LIST=$(pacman -Qq) ;;
    esac
    
    local TARGET_PKG=$(echo "$PKG_LIST" | fzf --prompt="Select package (Esc to cancel) > " --height=15 --layout=reverse)
    if [ -z "$TARGET_PKG" ]; then return; fi
    
    perform_downgrade "$TARGET_PKG" "$PKG_TYPE"
    if [ $? -eq 0 ]; then
        echo ""
        read -p "Place hold on $TARGET_PKG? (y/N): " hold_ans
        if [[ "$hold_ans" =~ ^[Yy]$ ]]; then
            read -p "Days to hold [Default: 7]: " HOLD_DAYS
            add_hold_entry "$TARGET_PKG" "$PKG_TYPE" "${HOLD_DAYS:-7}"
        fi
    else
        echo -e "\nDowngrade cancelled or failed."
    fi
    
    echo ""
    read -p "Press Enter to return to menu..."
}

create_hold_wizard() {
    local PKG_TYPE=$(printf "flatpak\napt\ndnf\npacman" | fzf --prompt="Select manager (Esc to cancel) > " --height=10 --layout=reverse)
    if [ -z "$PKG_TYPE" ]; then return; fi
    
    local PKG_LIST=""
    case $PKG_TYPE in
        flatpak) PKG_LIST=$(flatpak list --columns=application) ;;
        apt) PKG_LIST=$(dpkg-query -f '${Package}\n' -W) ;;
        dnf) PKG_LIST=$(dnf list installed | awk 'NR>1 {print $1}') ;;
        pacman) PKG_LIST=$(pacman -Qq) ;;
    esac
    
    local TARGET_PKG=$(echo "$PKG_LIST" | fzf --prompt="Select package (Esc to cancel) > " --height=15 --layout=reverse)
    if [ -z "$TARGET_PKG" ]; then return; fi
    
    read -p "Days to hold [Default: 7]: " HOLD_DAYS
    add_hold_entry "$TARGET_PKG" "$PKG_TYPE" "${HOLD_DAYS:-7}"
    
    echo ""
    read -p "Press Enter to return to menu..."
}

# --- Background Check ---

check_holds() {
    export XDG_RUNTIME_DIR="/run/user/$(id -u)"
    export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"
    export DISPLAY="${DISPLAY:-:0}"
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"

    local current_date=$(date +%s)
    local temp_file=$(mktemp)
    local expired_pkgs=() expired_types=() expired_exps=() expired_count=0
    
    while IFS='|' read -r pkg type exp_date; do
        if [ -z "$pkg" ]; then continue; fi
        if ! is_installed "$pkg" "$type"; then continue; fi

        if [ "$current_date" -ge "$exp_date" ]; then
            expired_pkgs+=("$pkg")
            expired_types+=("$type")
            expired_exps+=("$exp_date")
            ((expired_count++))
        else
            echo "$pkg|$type|$exp_date" >> "$temp_file"
        fi
    done < "$HOLD_FILE"
    
    if [ $expired_count -eq 0 ]; then
        mv "$temp_file" "$HOLD_FILE"
        return
    fi
    
    local user_action=""
    if command -v notify-send &> /dev/null; then
        user_action=$(notify-send -a "Rollback Manager" "Update Holds Expired" \
            "$expired_count package(s) have reached the end of their hold period." \
            --action="default=Review Holds" --action="review=Review Holds" --wait 2>/dev/null)
    else
        user_action="review"
    fi

    if [ "$user_action" != "review" ] && [ "$user_action" != "default" ]; then
        for i in "${!expired_pkgs[@]}"; do
            echo "${expired_pkgs[$i]}|${expired_types[$i]}|${expired_exps[$i]}" >> "$temp_file"
        done
        mv "$temp_file" "$HOLD_FILE"
        return 
    fi
    
    local pacman_pkgs="" flatpak_pkgs="" apt_pkgs="" dnf_pkgs=""
    
    for i in "${!expired_pkgs[@]}"; do
        local p="${expired_pkgs[$i]}"
        local t="${expired_types[$i]}"
        while true; do
            zenity --question --title="Hold Expired ($((i+1)) of $expired_count)" \
                   --text="Hold for $p ($t) has ended. Unhold and update?" \
                   --ok-label="Unhold & Update" --cancel-label="Hold longer" 2>/dev/null
            
            if [ $? -eq 0 ]; then
                echo "$p|$t|${expired_exps[$i]}" >> "$temp_file"
                case $t in
                    pacman) pacman_pkgs+="$p " ;;
                    flatpak) flatpak_pkgs+="$p " ;;
                    apt) apt_pkgs+="$p " ;;
                    dnf) dnf_pkgs+="$p " ;;
                esac
                break 
            else
                local extend_days=$(zenity --entry --title="Extend Hold" \
                    --text="Days to hold $p? (Blank for default: $DEFAULT_EXTEND_DAYS)" \
                    --entry-text="$DEFAULT_EXTEND_DAYS" 2>/dev/null)
                
                if [ $? -eq 0 ]; then
                    local days=${extend_days:-$DEFAULT_EXTEND_DAYS}
                    if [[ "$days" =~ ^[0-9]+$ ]]; then
                        echo "$p|$t|$(date -d "+$days days" +%s)" >> "$temp_file"
                        break 
                    fi
                else
                    continue
                fi
            fi
        done
    done
    
    mv "$temp_file" "$HOLD_FILE"
    
    local update_cmd=""
    if [ -n "$pacman_pkgs$flatpak_pkgs$apt_pkgs$dnf_pkgs" ]; then
        update_cmd="echo 'Authenticating...'; sudo -v; "
        if [ -n "$pacman_pkgs" ]; then
            for p in $pacman_pkgs; do update_cmd+="sudo bash -c \"sed -i 's/[[:space:]]*\\\\b${p}\\\\b//g' /etc/pacman.conf\" && sed -i \"/^${p}|pacman|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo pacman -S $pacman_pkgs; "
        fi
        if [ -n "$flatpak_pkgs" ]; then
            for p in $flatpak_pkgs; do update_cmd+="sudo flatpak mask --remove ${p} >/dev/null 2>&1 && sed -i \"/^${p}|flatpak|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo flatpak update -y $flatpak_pkgs; "
        fi
        if [ -n "$apt_pkgs" ]; then
            for p in $apt_pkgs; do update_cmd+="sudo apt-mark unhold ${p} >/dev/null 2>&1 && sed -i \"/^${p}|apt|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo apt-get --only-upgrade install -y $apt_pkgs; "
        fi
        if [ -n "$dnf_pkgs" ]; then
            for p in $dnf_pkgs; do update_cmd+="sudo dnf versionlock delete ${p} >/dev/null 2>&1 && sed -i \"/^${p}|dnf|/d\" \"$HOLD_FILE\" ; "; done
            update_cmd+="sudo dnf upgrade -y $dnf_pkgs; "
        fi
        
        # Scrub ANY trailing semicolons or whitespace safely using printf
        update_cmd=$(printf "%s" "$update_cmd" | sed 's/[[:space:];]*$//')
        launch_terminal "$update_cmd"
    fi
}

# --- Execution ---

if [ "$1" == "check" ]; then
    check_holds
else
    setup_systemd_timer
    while true; do
        clear
        action=$(printf "1. Create new hold\n2. Manage active holds\n3. Downgrade package\n4. Exit" | fzf --prompt="Select action (Esc to cancel) > " --height=8 --layout=reverse)
        case "$action" in
            "1. Create new hold") create_hold_wizard ;;
            "2. Manage active holds") manage_holds ;;
            "3. Downgrade package") downgrade_wizard ;;
            *) exit 0 ;;
        esac
    done
fi
